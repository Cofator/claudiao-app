# SPA fallback: serve index.html para qualquer rota que nao seja arquivo/pasta real.
# Necessario porque o cockpit usa BrowserRouter (rotas /c, /parear, etc.).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Cache dos assets com hash (imutaveis). O index.html nao cacheia.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|svg|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
